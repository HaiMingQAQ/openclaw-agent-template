{
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_TOKEN"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "accounts": {
        "default": {
          "botToken": "{{BOT_TOKEN}}",
          "dmPolicy": "pairing",
          "proxy": "{{PROXY}}"
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "deepseek/deepseek-v4-flash"
      },
      "timeoutSeconds": 120
    },
    "list": [
      {
        "id": "{{AGENT_ID}}",
        "name": "{{AI_NAME}}",
        "workspace": "{{WORKSPACE_PATH}}"
      }
    ]
  },
  "commands": {
    "ownerAllowFrom": [
      "telegram:{{MY_CHAT_ID}}"
    ]
  },
  "bindings": [
    {
      "agentId": "{{AGENT_ID}}",
      "match": {
        "channel": "telegram",
        "accountId": "default"
      }
    }
  ]
}
