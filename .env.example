# ===========================================
# OpenClaw AI 人格部署 - 环境变量配置
# ===========================================
# 复制此文件为 .env，然后填入你的值

# --- Telegram Bot ---
BOT_TOKEN=你的bot_token

# --- LLM API（至少填一个） ---
# DeepSeek
DEEPSEEK_API_KEY=sk-你的deepseek_key

# AIP 平台（GPT / Claude）
AIP_API_KEY=sk-你的aip_key

# SiliconFlow（图片生成/识别）
SILICONFLOW_API_KEY=你的siliconflow_key

# --- 用户配置 ---
# 你的 Telegram Chat ID
# 获取方法：给 bot 发一条消息，查看 openclaw status 中的 chat_id
MY_CHAT_ID=你的chat_id

# 时区
TIMEZONE=Asia/Shanghai

# --- AI 人格配置 ---
# Agent ID（唯一标识，如 "buddy"）
AGENT_ID=buddy

# AI 名字（也是工作区文件夹名）
AI_NAME=你的AI名字

# 你的称呼
USER_NAME=你的称呼

# --- 路径（一般不用改，脚本自动生成） ---
# Windows: C:\Users\你的用户名\.openclaw\workspace-{{AI_NAME}}
# Linux:   /home/你的用户名/.openclaw/workspace-{{AI_NAME}}
WORKSPACE_PATH=
